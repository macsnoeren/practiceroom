// PracticeRoom database schema.
// Provider is SQLite for a zero-install, self-hosted small setup.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A music school. The tenant boundary: all data belongs to exactly one school
/// and is never visible across schools.
model School {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  // Branding applied to every combined lesson video: an optional intro and
  // outro clip (stored on disk), and an overlay/watermark text.
  overlayText    String?
  introMimeType  String?
  introSizeBytes Int     @default(0)
  outroMimeType  String?
  outroSizeBytes Int     @default(0)

  users       User[]
  memberships Membership[]
  devices     Device[]
  lessons     Lesson[]
  holidays    Holiday[]
  rooms       Room[]
  library     LibraryItem[]
  sources     ComposedSource[]
}

/// A physical room/location where lessons take place. School-scoped.
model Room {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  createdAt DateTime @default(now())

  school  School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  devices Device[]
  sources ComposedSource[]

  @@index([schoolId])
}

/// A virtual "source" that overlays several of a room's cameras into one frame:
/// one main camera full-frame plus picture-in-picture insets in the corners
/// (e.g. an overview camera with a feet camera bottom-left). Recording it starts
/// every member camera in parallel; the worker composites them per segment.
model ComposedSource {
  id        String   @id @default(cuid())
  schoolId  String
  roomId    String
  name      String
  // The device whose sound is laid under this source (may be one of the video
  // members or a separate sound-only device, and need not belong to the room).
  // Null falls back to the room's audio-source device.
  audioDeviceId String?
  createdAt DateTime @default(now())

  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  room        Room                   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  audioDevice Device?                @relation("SourceAudioDevice", fields: [audioDeviceId], references: [id], onDelete: SetNull)
  members     ComposedSourceMember[]

  @@index([schoolId])
  @@index([roomId])
}

/// One camera within a composed source: the 'main' (full-frame) camera, or a
/// 'pip' inset placed in a corner at a fraction of the frame width.
model ComposedSourceMember {
  id       String  @id @default(cuid())
  sourceId String
  deviceId String
  role     String // 'main' | 'pip'
  position String? // 'bottom-left' | 'bottom-right' | 'top-left' | 'top-right' (pip only)
  scale    Float? // inset width as a fraction of the frame (pip only)
  order    Int     @default(0)

  source ComposedSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  device Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([deviceId])
}

/// A school holiday/break period. Recurring lessons skip weeks that fall in a
/// holiday. Students see holidays alongside their planning.
model Holiday {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  startsOn  DateTime
  endsOn    DateTime
  createdAt DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

/// A person. Access to a school and the role there live in `Membership` (a user
/// can belong to several schools). `schoolId`/`role` here are legacy: `role` is
/// only authoritative for a site-wide 'superadmin' (who has no membership);
/// `schoolId` is kept as the user's home school for display/compat.
model User {
  id           String   @id @default(cuid())
  schoolId     String? // home school (legacy); null for a site-wide superadmin
  email        String   @unique // globally unique so login needs only email + password
  name         String
  role         String // 'superadmin' (global); for members the role lives on Membership
  passwordHash  String
  emailVerified Boolean  @default(false)
  totpSecret    String? // TOTP shared secret (set while/after enabling 2FA)
  totpEnabled   Boolean  @default(false)
  // Brute-force lockout: count of consecutive failed logins, and a time until
  // which logins are refused once the threshold is hit. Both reset on success.
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  createdAt     DateTime @default(now())

  school         School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  memberships    Membership[]
  sessions       Session[]
  tokens         Token[]
  teacherLessons Lesson[]      @relation("TeacherLessons")
  studentLessons Lesson[]      @relation("StudentLessons")
  library        LibraryItem[]

  @@index([schoolId])
}

/// A user's membership of a school, with the role they hold there. One person
/// (one account/login) can be a member of several schools, with a different role
/// in each.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  schoolId  String
  role      String // 'admin' | 'teacher' | 'student'
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([userId, schoolId])
  @@index([schoolId])
}

/// A single-use, time-limited token for e-mail verification, password reset or
/// an account invitation. Only the sha256 hash is stored; the raw token lives
/// only in the e-mailed link.
model Token {
  id        String    @id @default(cuid())
  userId    String
  type      String // 'email_verify' | 'password_reset' | 'invite'
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// A capture device (camera/microphone), itself a browser app. It is created
/// by staff (unpaired), then paired by entering a short code, after which it
/// authenticates with a long-lived bearer token (only its hash is stored).
model Device {
  id               String    @id @default(cuid())
  schoolId         String
  name             String
  // 'camera' (captures video/audio) or 'speaker' (plays the room's sync tone on
  // command). Both pair and connect over the same device protocol.
  kind             String    @default("camera")
  // The room this device is installed in. Cameras of a room are shown together
  // in the control room; one device per room may be marked the audio source,
  // whose sound is laid under every video segment recorded in that room.
  roomId           String?
  isAudioSource    Boolean   @default(false)
  // Calibration: how many ms this device's video runs behind its audio. The
  // composite aligns on audio (the sync tone), then advances this device's video
  // by this much to cancel its capture-chain A/V skew. Positive = video lags.
  videoOffsetMs    Int       @default(0)
  pairingCode      String?   @unique // set while waiting to pair, cleared after
  pairingExpiresAt DateTime?
  tokenHash        String?   @unique // sha256 of the device token, set on pairing
  pairedAt         DateTime?
  lastSeenAt       DateTime?
  createdAt        DateTime  @default(now())

  school        School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  room          Room?                  @relation(fields: [roomId], references: [id], onDelete: SetNull)
  lessonDevices LessonDevice[]
  recordings    Recording[]
  sourceMembers ComposedSourceMember[]
  audioForSources ComposedSource[]     @relation("SourceAudioDevice")

  @@index([schoolId])
  @@index([roomId])
}

/// A planned lesson: a teacher and a student at a time, optionally filmed by
/// selected devices, with attached material. Status moves planned -> recording
/// -> recorded -> ready over later phases.
model Lesson {
  id              String   @id @default(cuid())
  schoolId        String
  teacherId       String
  studentId       String
  title           String?
  startsAt        DateTime
  durationMinutes Int
  status          String   @default("planned")
  seriesId        String? // links the lessons of one weekly-recurring series
  notes           String? // free-text lesson notes by the teacher
  studentNotes    String? // the student's own notes/questions about the lesson
  roomId          String?
  createdAt       DateTime @default(now())

  school     School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher    User            @relation("TeacherLessons", fields: [teacherId], references: [id], onDelete: Cascade)
  student    User            @relation("StudentLessons", fields: [studentId], references: [id], onDelete: Cascade)
  room       Room?           @relation(fields: [roomId], references: [id], onDelete: SetNull)
  devices    LessonDevice[]
  materials  Material[]
  recordings Recording[]
  tags       LessonTag[]
  composite  CompositeVideo?

  @@index([schoolId])
  @@index([teacherId])
  @@index([studentId])
  @@index([seriesId])
  @@index([roomId])
}

/// The single combined video for a lesson: its recording segments concatenated
/// in time order by the worker. One per lesson.
model CompositeVideo {
  id          String    @id @default(cuid())
  lessonId    String    @unique
  status      String    @default("queued") // queued | processing | completed | failed
  sizeBytes   Int       @default(0)
  error       String?
  // JSON diagnostics from the last build: per segment how its layers were aligned
  // (sync tone vs duration), with detected tone onsets and applied trims.
  syncReport  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

/// One recorded video file per device per lesson. Chunks are appended in order
/// during the lesson; `receivedChunks` enables resuming after an interruption.
model Recording {
  id             String    @id @default(cuid())
  lessonId       String
  deviceId       String
  status         String    @default("recording") // recording | completed | failed
  mimeType       String?
  hasVideo       Boolean   @default(true)
  hasAudio       Boolean   @default(true)
  // Optional crop rectangle as fractions (0–1) of the source frame, chosen on
  // the camera. All-null means no crop; the worker applies it before scaling.
  cropX          Float?
  cropY          Float?
  cropW          Float?
  cropH          Float?
  receivedChunks Int       @default(0)
  sizeBytes      Int       @default(0)
  // Segments started together (one camera + the room's audio source, or the
  // members of a composed source) share a group id; `isAudioTrack` marks the
  // audio-source segment whose sound the worker lays under the paired video.
  segmentGroupId String?
  isAudioTrack   Boolean   @default(false)
  // True when a sync tone was played for this segment's group, so the worker
  // aligns the members by detecting that tone in each track.
  syncTone       Boolean   @default(false)
  // Layout within a composed source: 'main' (full frame) or 'pip' (corner inset
  // at `layoutPosition`, width `layoutScale` of the frame). Null for a plain
  // single-camera segment.
  layoutRole     String?
  layoutPosition String?
  layoutScale    Float?
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@index([deviceId])
  @@index([segmentGroupId])
}

/// Which devices film a given lesson (many-to-many join).
model LessonDevice {
  lessonId String
  deviceId String

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@id([lessonId, deviceId])
  @@index([deviceId])
}

/// A timeline marker placed during a lesson ("hier ging het mis", "mooi stuk").
/// `at` is the wall-clock moment it was placed; a future editing tool can map it
/// onto the combined video's timeline.
model LessonTag {
  id        String   @id @default(cuid())
  lessonId  String
  label     String
  at        DateTime @default(now())
  createdAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

/// Teaching material attached to a lesson: a link, a note, and/or a video from
/// the teacher's library.
model Material {
  id            String   @id @default(cuid())
  lessonId      String
  title         String
  url           String?
  note          String?
  libraryItemId String?
  createdAt     DateTime @default(now())

  lesson  Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  library LibraryItem? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)

  @@index([lessonId])
  @@index([libraryItemId])
}

/// A video in a teacher's personal library, reusable across lessons. It is
/// either an uploaded/recorded file (streamed via signed URLs, like recordings)
/// or an external link.
model LibraryItem {
  id             String   @id @default(cuid())
  schoolId       String
  ownerId        String
  title          String
  description    String?
  kind           String // 'file' | 'link'
  url            String? // for 'link'
  mimeType       String? // for 'file'
  sizeBytes      Int      @default(0)
  receivedChunks Int      @default(0)
  status         String   @default("ready") // 'uploading' | 'ready'
  createdAt      DateTime @default(now())

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  materials Material[]

  @@index([schoolId])
  @@index([ownerId])
}

/// A security-relevant event (login, account/device change, …) for the
/// site-wide administrator to review. Deliberately has no foreign keys so a
/// record survives deletion of the user or school it refers to. Searchable
/// columns are kept alongside a JSON `detail` blob with the full context.
model AuditLog {
  id        String   @id @default(cuid())
  action    String // e.g. 'auth.login', 'device.revoke'
  schoolId  String? // tenant context, when known
  userId    String? // the acting/affected user, when known
  email     String? // e.g. the address used in a login attempt
  ip        String?
  detail    String? // JSON blob of the event's extra fields
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([schoolId])
}

/// A server-side login session, referenced by an opaque httpOnly cookie token.
model Session {
  id        String   @id // high-entropy random token (also the cookie value)
  userId    String
  // For a superadmin: the school they have currently "entered" (acting as its
  // admin). Null = managing the site / no school selected.
  activeSchoolId String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
