# Copy to .env and adjust as needed.
NODE_ENV=development
PORT=3000

# SQLite database file (relative to server/prisma/).
DATABASE_URL="file:./dev.db"

# Allowed origins (web dashboard + camera app), comma-separated.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Where recordings are written.
STORAGE_DIR=./storage

# Secret for signing playback URLs (use a strong random value in production).
SIGNING_SECRET=change-me

# ffmpeg binary path (empty = bundled @ffmpeg-installer; set to system/Docker ffmpeg otherwise)
FFMPEG_PATH=

# Cookies HTTPS-only. Defaults to on in production; leave unset for local dev.
# COOKIE_SECURE=false
