# Copy to .env and adjust as needed.
NODE_ENV=development
PORT=3000

# SQLite database file (relative to server/prisma/).
DATABASE_URL="file:./dev.db"

# Allowed origins (web dashboard + camera app), comma-separated.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Where recordings are written.
STORAGE_DIR=./storage

# Max size (MB) of one recording segment or library upload. Bounds disk usage
# against a misbehaving uploader. Default 1024; keep under 2000 (32-bit sizes).
# MAX_UPLOAD_MB=1024

# Secret for signing playback URLs (use a strong random value in production).
SIGNING_SECRET=change-me

# Key used to encrypt secrets at rest, e.g. TOTP secrets (strong random value in
# production). Changing it makes stored secrets undecryptable (re-enroll 2FA).
ENCRYPTION_KEY=change-me

# ffmpeg binary path (empty = bundled @ffmpeg-installer; set to system/Docker ffmpeg otherwise)
FFMPEG_PATH=
# ffprobe binary path (empty = bundled @ffprobe-installer)
FFPROBE_PATH=
# TrueType font for the lesson-video watermark. Empty = watermark is skipped.
# e.g. Windows: FONT_PATH=C:/Windows/Fonts/arial.ttf
FONT_PATH=

# Cookies HTTPS-only. Defaults to on in production; leave unset for local dev.
# COOKIE_SECURE=false

# Trust X-Forwarded-For from a reverse proxy so request.ip is the real client
# (used by rate limiting + audit logs). '1' = one proxy hop (the bundled nginx).
# Leave unset in local dev where the API is reached directly (XFF is spoofable).
# TRUST_PROXY=1

# Public URL of the dashboard, used for links in e-mails (verification, reset).
APP_URL=http://localhost:5173

# Outgoing mail (SMTP). Leave SMTP_HOST empty to disable sending — the app then
# logs the link it would have e-mailed (handy for local development).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# Wrap the password in double quotes if it contains a # or spaces, otherwise it
# gets cut off at the #:  SMTP_PASS="my#secret"
SMTP_PASS=
# From address (defaults to SMTP_USER when empty).
SMTP_FROM=
# TLS-on-connect (465) vs STARTTLS (587). Leave unset to infer from the port.
# SMTP_SECURE=false
