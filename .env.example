# Configuration for `docker compose` (copy to .env and fill in).

# A long, unique random string used to sign playback URLs. REQUIRED in
# production — the server refuses to start with the default.
#   e.g. generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIGNING_SECRET=change-me

# Public origins where browsers load the apps (dashboard + camera). With the
# default compose ports these are the host's web (8080) and camera (8081) URLs.
CORS_ORIGIN=http://localhost:8080,http://localhost:8081

# Cookies are HTTPS-only by default. Set to false ONLY for a local HTTP try-out.
COOKIE_SECURE=false
